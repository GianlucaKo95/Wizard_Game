#!/usr/bin/with-contenv bashio
set -e

bashio::log.info "Injecting Supabase config..."
SUPA_URL="${SUPABASE_URL:-}"
SUPA_KEY="${SUPABASE_ANON_KEY:-}"

if [ -z "${SUPA_URL}" ] || [ -z "${SUPA_KEY}" ]; then
    bashio::log.fatal "supabase_url und supabase_anon_key müssen konfiguriert sein!"
    exit 1
fi

find /app/frontend/dist -name "*.js" \
    -exec sed -i "s|__SUPABASE_URL__|${SUPA_URL}|g" {} \; \
    -exec sed -i "s|__SUPABASE_ANON_KEY__|${SUPA_KEY}|g" {} \;

bashio::log.info "Starte nginx auf Port 3043..."
exec nginx -g "daemon off;"
